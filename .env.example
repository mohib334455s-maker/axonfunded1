# Database (SQLite for local dev; use Postgres URL in production)
DATABASE_URL="file:./prisma/dev.db"

# Session JWT for trader accounts (min 16 chars; keep secret in production).
# Also used as the root for AES-256-GCM encryption of MT master/investor passwords at rest (TradingAccount).
AUTH_SECRET=

# Manual USDT (TRC20): when set to 1 and Stripe is NOT configured, checkout records `pending_usdt` orders until an admin confirms in /admin/usdt-orders.
MANUAL_USDT_SETTLEMENT=

# Stripe Checkout (Phase 2). When STRIPE_SECRET_KEY is set, mock POST /api/orders is disabled and card checkout uses Stripe.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Optional: public site URL for redirects if needed elsewhere (Checkout success/cancel URLs use the incoming request origin).
NEXT_PUBLIC_SITE_URL=
# Used in order confirmation emails (links to dashboard). Falls back to VERCEL_URL on Vercel.
NEXT_PUBLIC_APP_URL=

# Outbound email (SMTP) — order receipt after /api/orders/complete. Use credentials from your provider only in .env.local (never commit).
# Works with Zoho, Google Workspace (app password), SendGrid SMTP, Amazon SES SMTP, etc.
SMTP_HOST=
SMTP_PORT=587
# For port 465 set SMTP_SECURE=true
SMTP_SECURE=
SMTP_USER=
SMTP_PASSWORD=
# Optional display-from, e.g. "Axon <noreply@yourdomain.com>"
EMAIL_FROM=

# Resend (HTTPS API). If set, outbound mail uses Resend instead of SMTP.
RESEND_API_KEY=
# Verified domain from, e.g. "Axon <noreply@yourdomain.com>" — or use Resend onboarding sender for tests.
RESEND_FROM=

# Payout / risk (owner ops)
# Set to 1 on local/staging only — skips KYC + §11 funded-day gates for POST /api/dashboard/payouts.
PAYOUT_COMPLIANCE_RELAXED=
# Max simultaneous evaluation accounts awaiting or active per trader (rules §13 style cap).
MAX_CONCURRENT_CHALLENGES_PER_TRADER=3

# Axon AI — use one provider (OpenAI recommended)
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini

# Optional alternative (used only if OPENAI_API_KEY is unset)
ANTHROPIC_API_KEY=
ANTHROPIC_CHAT_MODEL=claude-3-5-haiku-20241022

# Trader sync bot → POST /api/trader/ingest (use a long random string; same value in scripts/.env.bot)
TRADER_INGEST_SECRET=

# MetaTrader EA telemetry → POST /api/mt/telemetry (same secret in EA input AxonTelemetrySecret)
MT_TELEMETRY_SECRET=

# ── Admin panel (required in production) ─────────────────────────────────────
# Signing key for HttpOnly admin session cookie (min 16 chars). Must match across instances.
AXON_ADMIN_SECRET=
# Login identifier (lowercased for compare).
ADMIN_EMAIL=admin@yourdomain.com
# Prefer bcrypt hash (never commit plaintext in repo). Generate: node -e "console.log(require('bcryptjs').hashSync('YourStrongPass',10))"
ADMIN_PASSWORD_HASH=
# Dev/staging only: if ADMIN_PASSWORD_HASH is unset, plain text compare (not for production).
# ADMIN_PASSWORD=

# Set to 1 to skip outbound IP reputation lookup (ip-api.com)
# DISABLE_IP_INTEL=
