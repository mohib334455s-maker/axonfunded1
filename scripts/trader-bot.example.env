# Copy to project root as `.env.bot` (gitignored). Do not commit secrets.

# Same secret as TRADER_INGEST_SECRET in the Next.js server (.env.local).
TRADER_INGEST_SECRET=replace-with-long-random-string

# Public URL of your running site (no trailing slash).
SITE_URL=http://localhost:3000

# Stable id for this trading account (letters, digits, ._- only, max 64 chars).
SYNC_ACCOUNT_ID=mt5-live-12345

# Push interval in milliseconds (minimum 10000).
SYNC_INTERVAL_MS=60000

# Optional: broker credentials — ONLY read by the bot on this machine to build `metrics`.
# They are never sent to Axon; implement fetchSnapshot() in scripts/trader-bot.mjs to use them.
BROKER_USER=
BROKER_PASSWORD=

# Until you wire a real API, the bot sends simulated numbers:
SIM_BALANCE=10000
SIM_EQUITY=10012.5
SIM_MARGIN=0
SIM_FREE_MARGIN=10000
SIM_PROFIT=12.5
SIM_OPEN_POSITIONS=0
SIM_NOTE=demo-stub
